# Backend URL (Railway URL after deploy, localhost for dev)
VITE_API_URL=http://localhost:8080

# Google OAuth Client ID (same one used in backend)
# Get from: console.cloud.google.com → APIs → Credentials → OAuth 2.0 Client IDs
# Add http://localhost:5173 to Authorized JavaScript origins for local dev
# Add your Vercel URL for production
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
